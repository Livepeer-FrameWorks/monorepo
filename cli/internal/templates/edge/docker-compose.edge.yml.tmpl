version: "3.9"

services:
  caddy:
    image: caddy:2
    container_name: edge-proxy
    ports:
      - "80:80"
      - "443:443"
    environment:
      - ACME_AGREE=true
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - ./maintenance.html:/etc/caddy/maintenance.html:ro
      - caddy_data:/data
      - caddy_config:/config
      - ./certs:/etc/frameworks/certs
      - caddy_admin:/run/caddy
    restart: unless-stopped

  mistserver:
    image: {{MISTSERVER_IMAGE}}
    container_name: mistserver
    command: ["MistController", "-c", "/etc/mistserver.conf", "-a", "frameworks:{{MIST_API_PASSWORD}}"]
    shm_size: "1g"
    ulimits:
      nofile:
        soft: 1048576
        hard: 1048576
    environment:
      - MIST_DEBUG=3
    expose:
      - "8080"
    restart: unless-stopped

  helmsman:
    image: frameworks/helmsman:latest
    container_name: helmsman
    ulimits:
      nofile:
        soft: 1048576
        hard: 1048576
    env_file:
      - .edge.env
    environment:
      - HELMSMAN_WEBHOOK_URL=http://helmsman:18007
      - MISTSERVER_URL=http://mistserver:8080
      - CADDY_ADMIN_SOCKET=/run/caddy/admin.sock
      - MIST_API_USERNAME=frameworks
      - MIST_API_PASSWORD={{MIST_API_PASSWORD}}
    volumes:
      - ./certs:/etc/frameworks/certs
      - ./pki:/etc/frameworks/pki
      - ./telemetry:/etc/frameworks/telemetry
      - caddy_admin:/run/caddy
    expose:
      - "18007"
    restart: unless-stopped

{{VMAGENT_EDGE_SERVICE}}

volumes:
  caddy_data: {}
  caddy_config: {}
  caddy_admin: {}
