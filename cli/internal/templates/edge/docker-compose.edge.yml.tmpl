services:
  edge:
    image: {{EDGE_IMAGE}}
    container_name: frameworks-edge
{{EDGE_NETWORK_BLOCK}}
    shm_size: "1g"
    ulimits:
      nofile:
        soft: 1048576
        hard: 1048576
    stop_grace_period: 1m
    env_file:
      - .edge.env
      - .edge-enroll.env
      - .edge-secrets.env
    environment:
      - MIST_API_USERNAME=frameworks
    volumes:
      - frameworks_opt:/opt/frameworks
      - frameworks_etc:/etc/frameworks
      - ./pki:/etc/frameworks/pki
      # rw: seed-edge sets ownership and helmsman rotates the token from
      # ConfigSeed; vmagent mounts this same dir read-only.
      - ./telemetry:/etc/frameworks/telemetry
      - caddy_etc:/etc/caddy
      - caddy_data:/var/lib/caddy
      - edge_storage:/data/storage
    restart: unless-stopped

{{EDGE_TUNING_SERVICE}}{{VMAGENT_EDGE_SERVICE}}
volumes:
  frameworks_opt: {}
  frameworks_etc: {}
  caddy_etc: {}
  caddy_data: {}
  edge_storage: {}
