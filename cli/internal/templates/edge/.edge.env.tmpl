# Edge stack environment
# Required: stable, unique node identity (human-friendly is fine)
NODE_ID={{NODE_ID}}

# Client-facing base URL (used for playback URLs + WebRTC pubhost)
EDGE_PUBLIC_URL=https://{{EDGE_DOMAIN}}/view

# Control-plane endpoints
FOGHORN_CONTROL_ADDR={{FOGHORN_GRPC_ADDR}}
GRPC_TLS_CA_PATH={{GRPC_TLS_CA_PATH}}

# TLS/Domain (manual DNS: A/AAAA {{EDGE_DOMAIN}} -> this host)
EDGE_DOMAIN={{EDGE_DOMAIN}}
ACME_EMAIL={{ACME_EMAIL}}

# Deployment mode: docker or native
DEPLOY_MODE={{DEPLOY_MODE}}

# Trusted CIDR for the local Mist->Helmsman relay hop (docker only: Mist
# dials helmsman:18007 over the compose bridge). Empty for native (loopback).
# Never set to a range that covers peer nodes — peer reads use Caddy + Bearer.
HELMSMAN_RELAY_TRUSTED_CIDR={{RELAY_TRUSTED_CIDR}}
