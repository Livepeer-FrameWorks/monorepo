# Edge stack environment
# Required: stable, unique node identity (human-friendly is fine)
NODE_ID={{NODE_ID}}

# Client-facing base URL (used for playback URLs + WebRTC pubhost)
EDGE_PUBLIC_URL=https://{{EDGE_DOMAIN}}/view

# Control-plane endpoints
FOGHORN_CONTROL_ADDR={{FOGHORN_GRPC_ADDR}}
GRPC_TLS_CA_PATH={{GRPC_TLS_CA_PATH}}

# TLS/Domain (manual DNS: A/AAAA {{EDGE_DOMAIN}} -> this host)
EDGE_DOMAIN={{EDGE_DOMAIN}}
ACME_EMAIL={{ACME_EMAIL}}

# Telemetry remote-write endpoint (informational: status/drift report it;
# vmagent reads its own config). Empty = telemetry disabled.
TELEMETRY_URL={{TELEMETRY_URL}}

# Deployment mode: container (single edge image) or native
DEPLOY_MODE={{DEPLOY_MODE}}

# Helmsman :18007 bind address. Loopback everywhere except the darwin bridge
# flavor (vmagent scrapes by service DNS there; 18007 is never published).
HELMSMAN_BIND_ADDR={{HELMSMAN_BIND_ADDR}}

# Trusted CIDR for the local Mist->Helmsman relay hop. Empty in both modes:
# Mist reaches Helmsman on loopback (native host, or inside the edge
# container). Never set to a range that covers peer nodes — peer reads use
# Caddy + Bearer.
HELMSMAN_RELAY_TRUSTED_CIDR={{RELAY_TRUSTED_CIDR}}
{{STORAGE_CAPACITY_BLOCK}}