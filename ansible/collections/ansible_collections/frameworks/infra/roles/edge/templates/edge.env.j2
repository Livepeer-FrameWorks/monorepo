# Edge stack environment (managed by frameworks.infra.edge)
NODE_ID={{ edge_node_id }}
CLUSTER_ID={{ edge_cluster_id }}
EDGE_PUBLIC_URL=https://{{ edge_domain }}/view
FOGHORN_CONTROL_ADDR={{ edge_foghorn_grpc_addr }}
{% if edge_ca_bundle_pem | length > 0 %}
GRPC_TLS_CA_PATH={{ edge_ca_path if edge_mode == 'native' else '/etc/frameworks/pki/ca.crt' }}
{% else %}
GRPC_TLS_CA_PATH=
{% endif %}
EDGE_DOMAIN={{ edge_domain }}
ACME_EMAIL={{ edge_acme_email | default('', true) }}
{# Informational: status/drift report it; vmagent reads its own config. #}
TELEMETRY_URL={{ edge_telemetry_url | default('', true) }}
DEPLOY_MODE={{ 'native' if edge_mode == 'native' else 'container' }}
{# Loopback bind everywhere except the darwin bridge flavor, where vmagent
   scrapes helmsman by service DNS and 18007 is not host-published. #}
HELMSMAN_BIND_ADDR={{ '' if (edge_mode != 'native' and edge_container_flavor | default('linux') == 'darwin') else '127.0.0.1' }}
HELMSMAN_RELAY_TRUSTED_CIDR={{ edge_relay_trusted_cidr | default('') }}
CADDY_CONFIG_PATH=/etc/caddy/Caddyfile
HELMSMAN_VERSION={{ edge_helmsman_version }}
MISTSERVER_VERSION={{ edge_mistserver_version }}
CADDY_VERSION={{ edge_caddy_version }}
FRAMEWORKS_CONFIG_SCHEMA_VERSION={{ edge_config_schema_version }}
HELMSMAN_BW_LIMIT_BYTES_PER_SEC={{ edge_bandwidth_limit_bytes_per_sec }}
HELMSMAN_MAX_TRANSCODES={{ edge_max_transcodes }}
HELMSMAN_STORAGE_CAPACITY_BYTES={{ edge_storage_capacity_bytes }}
HELMSMAN_STORAGE_LOCAL_PATH={{ edge_storage_local_path if edge_mode == 'native' else edge_docker_storage_local_path }}
HELMSMAN_CAP_INGEST={{ edge_cap_ingest }}
HELMSMAN_CAP_EDGE={{ edge_cap_edge }}
HELMSMAN_CAP_STORAGE={{ edge_cap_storage }}
HELMSMAN_CAP_PROCESSING={{ edge_cap_processing }}
