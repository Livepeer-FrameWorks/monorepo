global:
  scrape_interval: 30s
scrape_configs:
  - job_name: edge-mist
    metrics_path: /metrics
    static_configs:
      - targets:
{% if edge_mode == 'docker' %}
          - "mistserver:4242"
{% else %}
          - "127.0.0.1:4242"
{% endif %}
        labels:
          frameworks_mode: "edge"
          frameworks_node: "{{ edge_node_id }}"
          frameworks_service: "mistserver"
  - job_name: edge-helmsman
    metrics_path: /metrics
    static_configs:
      - targets:
{% if edge_mode == 'docker' %}
          - "helmsman:18007"
{% else %}
          - "127.0.0.1:18007"
{% endif %}
        labels:
          frameworks_mode: "edge"
          frameworks_node: "{{ edge_node_id }}"
          frameworks_service: "helmsman"
{% if edge_mode != 'docker' %}
  - job_name: edge-caddy
    metrics_path: /metrics
    static_configs:
      - targets:
          - "127.0.0.1:2019"
        labels:
          frameworks_mode: "edge"
          frameworks_node: "{{ edge_node_id }}"
          frameworks_service: "caddy"
{% endif %}
