{
    admin localhost:2019
    servers {
        protocols h1 h2 h3
    }
}

{{ edge_domain }}:443 {
    tls internal

    handle /health {
        respond "ok" 200
    }

    handle_path /webhooks/* {
        reverse_proxy localhost:18007
    }

    @mist_admin {
        path /_mist /_mist/*
    }
    handle @mist_admin {
        reverse_proxy localhost:18007
    }

    respond "Node bootstrapping - awaiting activation" 503
}

{{ edge_domain }}:80 {
    respond "Node bootstrapping" 503
}
