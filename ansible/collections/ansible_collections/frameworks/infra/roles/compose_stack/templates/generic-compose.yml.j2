services:
  {{ compose_stack_name }}:
    image: {{ compose_stack_service.image }}
    container_name: frameworks-{{ compose_stack_name }}
    restart: always
{% if compose_stack_service.port | default(0) | int > 0 %}
    ports:
      - "{{ compose_stack_service.port }}:{{ compose_stack_service.port }}"
{% endif %}
    networks:
      - frameworks
{% if (compose_stack_service.port | default(0) | int > 0) and (compose_stack_service.health_path | default('')) | length > 0 %}
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://127.0.0.1:{{ compose_stack_service.port }}{{ compose_stack_service.health_path }} || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 20s
{% endif %}
networks:
  frameworks:
    driver: bridge
