[Unit]
Description=VictoriaMetrics Auth
After=network-online.target
Wants=network-online.target

[Service]
User={{ prometheus_stack_user }}
Group={{ prometheus_stack_group }}
ExecStart={{ vmauth_bin }} \
  -httpListenAddr=:{{ vmauth_port }} \
  -auth.config={{ vmauth_config_path }}
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
