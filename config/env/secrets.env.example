# Copy to config/env/secrets.env and customize for your environment.
# These values are ignored by git.
#
# Credential lifecycle:
#   Operator-provided  — you MUST set these (passwords, API keys, external services)
#   CLI auto-generated — left as "change-me", the CLI generates random values at provision time
#                        and persists them to secrets/generated.env in your gitops repo
#   CLI-derived        — computed from manifest (DATABASE_URL, KAFKA_BROKERS, COOKIE_DOMAIN)
#
# For production: encrypt this file with SOPS+age (see external-services docs).

# ── Database credentials (operator-provided) ──────────────────────────
# Production: the CLI creates this role during provisioning and uses it
# to build DATABASE_URL for all application services.
DATABASE_USER=frameworks
DATABASE_PASSWORD=change-me

# Docker-compose local dev (Postgres container init)
POSTGRES_USER=frameworks_user
POSTGRES_PASSWORD=change-me

# ── ClickHouse credentials (operator-provided) ────────────────────────
# Deployed to /etc/clickhouse-server/users.xml via CLI provisioning.
# The "frameworks" user gets full access to periscope DB.
# The "readonly_user" gets rate-limited read access (1000 queries/hr).
CLICKHOUSE_USER=frameworks
CLICKHOUSE_PASSWORD=change-me
CLICKHOUSE_READONLY_PASSWORD=change-me

# ── Security (CLI auto-generated if "change-me") ─────────────────────
# These are auto-generated by `frameworks cluster provision` when left
# as placeholders. Generated values are persisted to secrets/generated.env.
JWT_SECRET=change-me
PASSWORD_RESET_SECRET=change-me-reset-key
SERVICE_TOKEN=change-me
USAGE_HASH_SECRET=change-me

# Application-level field encryption (AES-256-GCM via HKDF).
# Used by Navigator to encrypt TLS private keys at rest.
# Must be at least 32 characters. Auto-generated if "change-me".
FIELD_ENCRYPTION_KEY=change-me

# Navigator internal CA import (production required).
# Provisioning now refuses a production Navigator deploy unless you provide
# one complete source of managed CA material:
# 1. file paths that already exist on the target host, or
# 2. base64-encoded PEM env vars for direct secret delivery via GitOps.
NAVIGATOR_INTERNAL_CA_ROOT_CERT_FILE=
NAVIGATOR_INTERNAL_CA_INTERMEDIATE_CERT_FILE=
NAVIGATOR_INTERNAL_CA_INTERMEDIATE_KEY_FILE=
NAVIGATOR_INTERNAL_CA_ROOT_CERT_PEM_B64=
NAVIGATOR_INTERNAL_CA_INTERMEDIATE_CERT_PEM_B64=
NAVIGATOR_INTERNAL_CA_INTERMEDIATE_KEY_PEM_B64=

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
VM_HTTP_AUTH_USERNAME=telemetry
VM_HTTP_AUTH_PASSWORD=change-me

# Payment integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOLLIE_API_KEY=

# Crypto payment detection (optional)
HD_WALLET_XPUB=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# x402 settlement (optional)
X402_GAS_WALLET_PRIVKEY=
X402_GAS_WALLET_ADDRESS=

# Supplier info for invoicing (REQUIRED for x402 payments)
# These are printed on all invoices - use your legal entity details
SUPPLIER_NAME=
SUPPLIER_ADDRESS=
SUPPLIER_VAT_NUMBER=

# Cloudflare Turnstile (Bot Protection)
# Auth keys (for registration/login)
TURNSTILE_AUTH_SECRET_KEY=
TURNSTILE_AUTH_SITE_KEY=

# Forms keys (for contact forms)
TURNSTILE_FORMS_SECRET_KEY=
TURNSTILE_FORMS_SITE_KEY=

# Cloudflare DNS & Load Balancing (CLI usage)
# Required for: frameworks dns commands
# Create API token at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone.DNS (Edit), Account.Load Balancers (Edit)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# MistServer API credentials
MIST_API_USERNAME=test
MIST_API_PASSWORD=test

# SMTP Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=info@frameworks.network
FROM_NAME=info@frameworks.network
TO_EMAIL=contact@frameworks.network

# Skipper (AI Video Consultant)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_API_URL=

# Embedding provider (falls back to LLM_* when unset).
# Required when LLM_PROVIDER does not support embeddings (e.g. anthropic).
# Options: OpenAI (text-embedding-3-small), Livepeer (nomic-embed-text, free beta)
# Skipper auto-detects dimensions at startup — no manual config needed.
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_API_URL=

SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_API_URL=

# Utility LLM for background tasks (contextual retrieval, query rewriting, HyDE).
# Falls back to LLM_* when unset.
# Options: OpenAI (gpt-4o-mini), Livepeer (qwen3:8b, free beta)
UTILITY_LLM_PROVIDER=
UTILITY_LLM_MODEL=
UTILITY_LLM_API_KEY=
UTILITY_LLM_API_URL=

# Cross-encoder reranker (optional). Providers: cohere, jina, generic.
# Falls back to keyword heuristic when unset.
# Options: Cohere (rerank-v3.5), Jina (jina-reranker-v2-base-multilingual),
#          Livepeer (zeroentropy/zerank-2, BYOC — 8GB VRAM)
RERANKER_PROVIDER=
RERANKER_MODEL=
# RERANKER_API_KEY falls back to LLM_API_KEY; RERANKER_API_URL required for "generic"
RERANKER_API_KEY=
# RERANKER_API_URL= # Required for "generic" provider only
# Livepeer reranker (uses generic provider):
# RERANKER_PROVIDER=generic
# RERANKER_MODEL=zeroentropy/zerank-2
# RERANKER_API_URL=https://openai-gateway.livepeer.cloud/v1

# Listmonk (Newsletter) API
LISTMONK_URL=http://listmonk:9000
LISTMONK_USERNAME=admin
LISTMONK_PASSWORD=change-me

# Chatwoot (support chat)
# SECRET_KEY_BASE for Chatwoot Rails app - generate with: openssl rand -hex 64
CHATWOOT_SECRET_KEY=change-me
# SETUP REQUIRED: See website_docs/.../operators/chatwoot-setup.mdx
CHATWOOT_API_TOKEN=
# Connection details (defaults work for docker-compose)
CHATWOOT_HOST=chatwoot
CHATWOOT_PORT=3000
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# Storage S3 (for Foghorn cold storage - optional)
STORAGE_S3_BUCKET=
STORAGE_S3_PREFIX=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
