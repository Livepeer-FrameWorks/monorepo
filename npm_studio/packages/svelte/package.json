{
  "name": "@livepeer-frameworks/streamcrafter-svelte",
  "version": "0.3.3",
  "type": "module",
  "description": "Svelte 5 stores for StreamCrafter browser streaming",
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./streamcrafter.css": "./src/streamcrafter.css"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "build:watch": "svelte-package -i src -o dist --watch",
    "type-check": "svelte-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@livepeer-frameworks/streamcrafter-core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "streaming",
    "webcodecs",
    "whip",
    "webrtc",
    "ingest"
  ],
  "author": "Livepeer FrameWorks",
  "license": "Unlicense"
}
