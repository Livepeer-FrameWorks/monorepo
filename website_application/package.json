{
  "name": "frameworks-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "prebuild": "../scripts/copy-agent-files.sh static",
    "build": "houdini generate && vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --plugin-search-dir . --check . && eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "gql:codegen": "houdini generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.0",
    "@lezer/highlight": "^1.2.3",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/codemirror": "^5.60.17",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "formsnap": "^2.0.1",
    "globals": "^17.4.0",
    "houdini": "2.0.0-next.11",
    "houdini-svelte": "3.0.0-next.13",
    "jsdom": "^29.0.2",
    "mode-watcher": "^1.1.0",
    "postcss": "^8.5.9",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "type": "module",
  "files": [
    "build",
    "static"
  ],
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/tooltip": "^0.19.16",
    "@frameworks/site-config": "workspace:^",
