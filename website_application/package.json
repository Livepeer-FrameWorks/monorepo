    "@sveltejs/kit": "^2.57.0",
    "@tanstack/svelte-query": "^6.1.14",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.15.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cm6-graphql": "^0.2.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "graphql": "^16.13.2",
    "graphql-language-service": "^5.5.0",
    "graphql-ws": "^6.0.8",
    "h3-js": "^4.4.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.55.2",
    "svelte-chartjs": "^4.0.1",
    "svelte-turnstile": "^0.11.0",
