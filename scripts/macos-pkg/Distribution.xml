<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>FrameWorks</title>
    <organization>com.livepeer.frameworks</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>

    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default">
            <line choice="com.livepeer.frameworks"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="com.livepeer.frameworks"
            visible="false"
            title="FrameWorks"
            description="FrameWorks CLI and desktop application">
        <pkg-ref id="com.livepeer.frameworks"/>
    </choice>

    <pkg-ref id="com.livepeer.frameworks"
             version="0"
             onConclusion="none">frameworks-component.pkg</pkg-ref>

    <os-requirements>
        <os-version min="14.0"/>
    </os-requirements>

    <system-requirements>
        <allowed-os-versions>
            <os-version min="14.0"/>
        </allowed-os-versions>
    </system-requirements>
</installer-gui-script>
