#!/command/with-contenv sh
# Parity with the native unit's ExecStartPre: stale shared-memory pages from
# a previous MistController would wedge the new one.
rm -f /dev/shm/Mst* /dev/shm/sem.MstSemStat 2>/dev/null || true
export LD_LIBRARY_PATH=/opt/frameworks/mistserver/lib
MIST_API_USERNAME="${MIST_API_USERNAME:-frameworks}"
if [ -n "${MIST_API_PASSWORD}" ]; then
  exec s6-setuidgid frameworks /opt/frameworks/mistserver/bin/MistController \
    -c /etc/frameworks/mistserver.conf -a "${MIST_API_USERNAME}:${MIST_API_PASSWORD}"
fi
exec s6-setuidgid frameworks /opt/frameworks/mistserver/bin/MistController \
  -c /etc/frameworks/mistserver.conf
