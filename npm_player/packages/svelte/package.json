{
  "name": "@livepeer-frameworks/player-svelte",
  "version": "0.5.3",
  "type": "module",
  "description": "Svelte 5 components for FrameWorks streaming player",
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./player.css": {
      "source": "./src/player.css",
      "default": "./dist/player.css"
    }
  },
  "scripts": {
    "build": "svelte-package -i src -o dist && pnpm run build:css",
    "build:css": "cp ../core/src/styles/player.css ./dist/player.css",
    "build:watch": "svelte-package -i src -o dist --watch",
    "type-check": "svelte-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@livepeer-frameworks/player-core": "workspace:*",
    "bits-ui": "^2.18.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "svelte": "^5.56.0",
    "svelte-check": "^4.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "streaming",
    "player",
    "video"
  ],
  "author": "Livepeer FrameWorks",
  "license": "Unlicense"
}
